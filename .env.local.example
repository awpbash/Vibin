# Required for real pipeline. Mock data works without these.

OPENAI_API_KEY=
GEMINI_API_KEY=
FAL_API_KEY=
YOUTUBE_API_KEY=

GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Cloudflare R2 for hosting generated MP4s
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=viber-vibes
R2_PUBLIC_BASE_URL=

# Toggle to disable real API calls and use fixtures.
# Solo mode: leave true until keys are wired.
USE_MOCK_PIPELINE=true

# Local data directory for vibe persistence (JSON sidecar).
VIBE_DATA_DIR=./.viber
